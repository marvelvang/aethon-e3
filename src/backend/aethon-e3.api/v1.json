{
  "openapi": "3.1.0",
  "info": {
    "title": "aethon-e3.api",
    "version": "1.0.0"
  },
  "paths": {
    "/api/game": {
      "post": {
        "tags": ["Game"],
        "operationId": "CreateGame",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          }
        }
      }
    },
    "/api/game/{id}": {
      "get": {
        "tags": ["Game"],
        "operationId": "GetState",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/game/{id}/buildings": {
      "post": {
        "tags": ["Game"],
        "operationId": "BuildBuilding",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBuildingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/game/{id}/round": {
      "post": {
        "tags": ["Game"],
        "operationId": "EndRound",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BuildingType": {
        "type": "string",
        "enum": ["Base", "Housing", "Consumer", "Industry"]
      },
      "PlaceBuildingRequest": {
        "type": "object",
        "properties": {
          "x": {
            "type": "integer",
            "format": "int32"
          },
          "y": {
            "type": "integer",
            "format": "int32"
          },
          "type": {
            "$ref": "#/components/schemas/BuildingType"
          }
        },
        "required": ["x", "y", "type"]
      },
      "UiBuildingSlot": {
        "type": "object",
        "properties": {
          "x": {
            "type": "integer",
            "format": "int32"
          },
          "y": {
            "type": "integer",
            "format": "int32"
          },
          "type": {
            "$ref": "#/components/schemas/BuildingType"
          },
          "isNewlyBuilt": {
            "type": "boolean"
          }
        },
        "required": ["x", "y", "type", "isNewlyBuilt"]
      },
      "UiBuildingTypeInfo": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/BuildingType"
          },
          "populationCost": {
            "type": "integer",
            "format": "int32"
          },
          "industryCost": {
            "type": "integer",
            "format": "int32"
          },
          "canAfford": {
            "type": "boolean"
          }
        },
        "required": ["type", "populationCost", "industryCost", "canAfford"]
      },
      "UiState": {
        "type": "object",
        "properties": {
          "gameStateId": {
            "type": "integer",
            "format": "int32"
          },
          "round": {
            "type": "integer",
            "format": "int32"
          },
          "population": {
            "type": "integer",
            "format": "int32"
          },
          "freePopulation": {
            "type": "integer",
            "format": "int32"
          },
          "boundPopulation": {
            "type": "integer",
            "format": "int32"
          },
          "consumerGoods": {
            "type": "integer",
            "format": "int32"
          },
          "industry": {
            "type": "integer",
            "format": "int32"
          },
          "housing": {
            "type": "integer",
            "format": "int32"
          },
          "buildings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UiBuildingSlot"
            }
          },
          "buildingTypes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UiBuildingTypeInfo"
            }
          }
        },
        "required": ["gameStateId", "round", "population", "freePopulation", "boundPopulation", "consumerGoods", "industry", "housing", "buildings", "buildingTypes"]
      }
    }
  }
}
