{
  "openapi": "3.1.1",
  "info": {
    "title": "aethon-e3.api | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "aethon-e3.api"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/game": {
      "post": {
        "tags": [
          "Game"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          }
        }
      }
    },
    "/api/game/{id}": {
      "get": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/game/{id}/buildings": {
      "post": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBuildingRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBuildingRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBuildingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          }
        }
      }
    },
    "/api/game/{id}/round": {
      "post": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UiState"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BuildingType": {
        "enum": [
          "Base",
          "Housing",
          "Consumer",
          "Industry"
        ]
      },
      "PlaceBuildingRequest": {
        "required": [
          "x",
          "y",
          "type"
        ],
        "type": "object",
        "properties": {
          "x": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "y": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "type": {
            "$ref": "#/components/schemas/BuildingType"
          }
        }
      },
      "UiBuildingSlot": {
        "required": [
          "x",
          "y",
          "type",
          "isNewlyBuilt"
        ],
        "type": "object",
        "properties": {
          "x": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "y": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "type": {
            "$ref": "#/components/schemas/BuildingType"
          },
          "isNewlyBuilt": {
            "type": "boolean"
          }
        }
      },
      "UiBuildingTypeInfo": {
        "required": [
          "type",
          "populationCost",
          "industryCost",
          "canAfford"
        ],
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/BuildingType"
          },
          "populationCost": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "industryCost": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "canAfford": {
            "type": "boolean"
          }
        }
      },
      "UiState": {
        "required": [
          "gameStateId",
          "round",
          "population",
          "freePopulation",
          "boundPopulation",
          "consumerGoods",
          "industry",
          "housing",
          "consumerGoodsGain",
          "industryGain",
          "housingGain",
          "populationGain",
          "buildings",
          "buildingTypes"
        ],
        "type": "object",
        "properties": {
          "gameStateId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "round": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "population": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "freePopulation": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "boundPopulation": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "consumerGoods": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "industry": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "housing": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "consumerGoodsGain": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "industryGain": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "housingGain": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "populationGain": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "buildings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UiBuildingSlot"
            }
          },
          "buildingTypes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UiBuildingTypeInfo"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "aethon-e3.api"
    },
    {
      "name": "Game"
    }
  ]
}