{
  "name": "aethon-e3",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared/models",
    "shared/engine",
    "shared/api-contract",
    "frontend/app",
    "frontend/api-client",
    "backend/app",
    "backend/persistence"
  ],
  "scripts": {
    "build:frontend": "bun --filter @aethon/frontend build",
    "dev:frontend": "bun --filter @aethon/frontend dev",
